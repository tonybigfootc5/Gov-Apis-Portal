generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProgramLevel {
  FOUNDATION
  ADVANCED
  PROFESSIONAL
}

enum EventStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum MediaAssetType {
  IMAGE
  VIDEO
  ARTICLE_ASSET
}

enum ApplicationAttemptStatus {
  ATTEMPTED
  SUBMITTED
  PAYMENT_INITIATED
  PAYMENT_FAILED
  PAYMENT_COMPLETED
}

enum ApplicationApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationCrossCheckStatus {
  PENDING
  VERIFIED
}

enum PaymentProvider {
  PHONEPE
}

enum PaymentEnvironment {
  SANDBOX
  PRODUCTION
}

enum PaymentOrderState {
  CREATED
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUND_PENDING
  REFUNDED
  REFUND_FAILED
}

enum RefundState {
  REQUESTED
  COMPLETED
  FAILED
}

model Program {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  summary          String
  description      String
  duration         String
  level            ProgramLevel @default(FOUNDATION)
  fee              String?
  capacity         Int          @default(30)
  batchStartsAt    DateTime?
  enrollmentClosed Boolean      @default(false)
  popupEnabled     Boolean      @default(true)
  published        Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Event {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  summary     String
  description String
  location    String
  startsAt    DateTime
  endsAt      DateTime?
  status      EventStatus @default(UPCOMING)
  published   Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Article {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String
  body            String
  category        String
  publishedAt     DateTime
  authorName      String
  authorRole      String
  mediaUrl        String?
  mediaObjectKey  String?
  mediaType       MediaAssetType?
  externalLink    String?
  keyPoints       String
  seoTitle        String
  metaDescription String
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  caption   String
  date      DateTime
  place     String?
  category  String
  year      Int
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  ipHash    String?
  createdAt DateTime @default(now())
}

model TrainingApplication {
  id                     String                         @id @default(cuid())
  legacyMessageId        String?                        @unique
  applicationNumber      Int?                           @unique
  batchCode              String?
  batchSequenceNumber    Int?
  serviceName            String
  applicationDate        String
  candidateName          String
  guardianName           String
  email                  String
  gender                 String
  dateOfBirth            String
  addressLine            String
  mandal                 String
  district               String
  state                  String
  pinCode                String
  phone                  String
  residencePhone         String
  educationQualification String
  occupation             String
  sponsoringOrganization String
  photoName              String
  photoType              String
  photoUrl               String?
  photoObjectKey         String?
  photoDataUrl           String?
  attemptStatus          ApplicationAttemptStatus      @default(SUBMITTED)
  approvalStatus         ApplicationApprovalStatus     @default(PENDING)
  crossCheckStatus       ApplicationCrossCheckStatus   @default(PENDING)
  adminNotes             String                         @default("")
  approvedAt             DateTime?
  approvedBy             String?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  paymentOrders          PaymentOrder[]

  @@unique([batchCode, batchSequenceNumber])
  @@index([batchCode, batchSequenceNumber])
}

model PaymentOrder {
  id                    String             @id @default(cuid())
  trainingApplicationId String
  trainingApplication   TrainingApplication @relation(fields: [trainingApplicationId], references: [id], onDelete: Cascade)
  provider              PaymentProvider    @default(PHONEPE)
  environment           PaymentEnvironment
  merchantOrderId       String             @unique
  phonePeOrderId        String?
  checkoutUrl           String?
  redirectUrl           String
  status                PaymentOrderState  @default(CREATED)
  amountPaise           Int
  currency              String             @default("INR")
  paymentReference      String?
  paidAt                DateTime?
  failedAt              DateTime?
  expiresAt             DateTime?
  refundEligible        Boolean            @default(false)
  latestErrorCode       String?
  latestErrorMessage    String?
  latestEventName       String?
  meta                  Json?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  paymentEvents         PaymentEvent[]
  refundRequests        RefundRequest[]

  @@index([trainingApplicationId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model PaymentEvent {
  id                  String       @id @default(cuid())
  paymentOrderId      String
  paymentOrder        PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
  dedupeKey           String       @unique
  eventName           String
  source              String
  state               String?
  authorizationHeader String?
  payload             Json
  receivedAt          DateTime     @default(now())

  @@index([paymentOrderId, receivedAt(sort: Desc)])
}

model RefundRequest {
  id                    String       @id @default(cuid())
  paymentOrderId        String
  paymentOrder          PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
  merchantRefundId      String       @unique
  phonePeRefundId       String?
  amountPaise           Int
  reason                String
  requestedBy           String?
  status                RefundState  @default(REQUESTED)
  completedAt           DateTime?
  failedAt              DateTime?
  failureCode           String?
  failureMessage        String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([paymentOrderId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
